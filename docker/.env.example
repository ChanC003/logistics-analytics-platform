# Airflow metadata DB (PostgreSQL)
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=your-airflow-db-password
AIRFLOW_DB_NAME=airflow

# Airflow web admin
AIRFLOW_ADMIN_USER=airflow
AIRFLOW_ADMIN_PASSWORD=your-airflow-admin-password

# Airflow internals
AIRFLOW_FERNET_KEY=your-fernet-key-32chars-base64-padded==
AIRFLOW_SECRET_KEY=your-secret-key
